{
  "name": "rolemesh-webui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "openapi:gen": "openapi-typescript ./openapi.yaml -o ./src/api/generated/types.ts",
    "openapi:check": "openapi-typescript ./openapi.yaml -o /tmp/rm-openapi-types.ts && diff -u ./src/api/generated/types.ts /tmp/rm-openapi-types.ts"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "lit": "^3.3",
    "marked": "^15",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4",
    "typescript": "^5.7",
    "vite": "^6"
  }
}
