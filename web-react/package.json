{
  "name": "rolemesh-webui-react",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "openapi:gen": "openapi-typescript ../contracts/openapi.yaml -o ./src/api/generated/types.ts",
    "openapi:check": "openapi-typescript ../contracts/openapi.yaml -o /tmp/rm-react-openapi.ts && diff -u ./src/api/generated/types.ts /tmp/rm-react-openapi.ts",
    "test": "vitest run",
    "lint:flat-route": "node scripts/lint-flat-route.mjs",
    "lint:tokens-only": "node scripts/lint-tokens-only.mjs",
    "lint:no-admin-chat": "node scripts/lint-no-admin-chat.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "ajv": "^8.20.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.560.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19.2",
    "@types/react-dom": "^19.2",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.24",
    "happy-dom": "^20.10.6",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.6",
    "tailwindcss": "3.4.19",
    "typescript": "~5.9.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
